  "devDependencies": {
    "@biomejs/biome": "^2.4.6",
    "@types/node": "^24.10.1",
    "@types/react": "^19.2.5",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "baseline-browser-mapping": "^2.9.19",
    "typescript": "~5.9.3",
    "vite": "^7.2.4"
