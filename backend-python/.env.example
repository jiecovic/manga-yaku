# ============================
# CLOUD OPENAI
# ============================
OPENAI_API_KEY=

# Default base URL for OpenAI SDK
# (Do NOT modify unless you're overriding it)
OPENAI_BASE_URL=https://api.openai.com/v1
AGENT_MODEL=gpt-5.4
AGENT_TEMPERATURE=0.2
AGENT_MAX_OUTPUT_TOKENS=2048
AGENT_MAX_MESSAGE_CHARS=2000
AGENT_REASONING_EFFORT=medium
AGENT_PROMPT_FILE=agent/chat/default.yml
AGENT_MODELS=gpt-5.4,gpt-5.4-pro,gpt-5.2,gpt-5-mini,gpt-4.1

# ============================
# LOCAL OPENAI-COMPATIBLE SERVER
# ============================
# The "OpenAI-compatible" model served locally at http://127.0.0.1:5000
# Many servers (LM Studio, vLLM, llama.cpp REST, etc.) expose /v1
LOCAL_OPENAI_BASE_URL=http://127.0.0.1:5000/v1
LOCAL_OPENAI_MODEL=local-model

# ============================
# DATABASE (Postgres + pgvector)
# ============================
DATABASE_URL=postgresql+psycopg://mangayaku:mangayaku@localhost:5433/mangayaku
DB_INIT=true

# ============================
# CORS / DEBUG / LOGGING
# ============================
CORS_ORIGINS=http://localhost:5174
CORS_ALLOW_CREDENTIALS=false
DEBUG_PROMPTS=false
LOG_LEVEL=INFO
